{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "important_articles",
  "title": "Important Articles",
  "description": "Validated article list produced by the evidence validator, grouped by relevance.",
  "type": "object",
  "required": ["validated_at", "total_articles", "by_relevance"],
  "properties": {
    "validated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the validation run completed."
    },
    "total_articles": {
      "type": "integer",
      "minimum": 0,
      "description": "Total count of articles across all relevance tiers."
    },
    "by_relevance": {
      "type": "object",
      "description": "Articles grouped by relevance tier.",
      "required": ["critical", "high", "medium", "low"],
      "properties": {
        "critical": { "$ref": "#/$defs/article_array" },
        "high": { "$ref": "#/$defs/article_array" },
        "medium": { "$ref": "#/$defs/article_array" },
        "low": { "$ref": "#/$defs/article_array" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "article_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/article" }
    },
    "article": {
      "type": "object",
      "required": ["title", "date", "source", "url", "path", "score", "relevance", "matched_keywords"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Article headline."
        },
        "date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
          "description": "Publication date (YYYY-MM-DD)."
        },
        "source": {
          "type": "string",
          "description": "Source name (e.g. Texas Tribune, KVUE)."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Canonical URL of the article."
        },
        "path": {
          "type": "string",
          "pattern": "^_posts/[^/]+\\.md$",
          "description": "Relative path to the Jekyll post file."
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "description": "Relevance score from keyword matching."
        },
        "relevance": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "description": "Relevance tier for the article."
        },
        "matched_keywords": {
          "type": "array",
          "items": { "$ref": "#/$defs/matched_keyword" },
          "description": "Keywords matched and their contribution to the score."
        },
        "url_reachable": {
          "type": "boolean",
          "description": "Whether the source URL was reachable during validation."
        },
        "content_match_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Ratio of post content that matches the source (0-1)."
        }
      },
      "additionalProperties": false
    },
    "matched_keyword": {
      "type": "object",
      "required": ["keyword", "priority", "count", "score"],
      "properties": {
        "keyword": {
          "type": "string",
          "description": "Matched keyword or phrase."
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "description": "Priority tier of the keyword."
        },
        "count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of occurrences in the article."
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "description": "Score contribution from this keyword."
        }
      },
      "additionalProperties": false
    }
  }
}
